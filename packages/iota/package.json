{
  "name": "@typemove/iota",
  "version": "1.0.0-development",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentioxyz/typemove.git",
    "directory": "packages/iota"
  },
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js",
    "./codegen": "./dist/esm/codegen/index.js",
    "./builtin": "./dist/esm/builtin/index.js",
    "./builtin/0x1": "./dist/esm/builtin/0x1.js",
    "./builtin/0x2": "./dist/esm/builtin/0x2.js",
    "./builtin/0x3": "./dist/esm/builtin/0x3.js"
  },
  "bin": {
    "typemove-iota": "./dist/esm/codegen/run.js"
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.*",
    "!**/tests"
  ],
  "scripts": {
    "_gen": "pnpm gen:test && tsx src/codegen/run.ts -t src/builtin -a src/abis",
    "build": "pnpm gen && tsc",
    "build:all": "pnpm --filter=$(node -p \"require('./package.json').name\")... build",
    "gen": "pnpm _gen 0x1 && pnpm _gen 0x2 && pnpm _gen 0x3",
    "gen:test": "tsx src/codegen/run.ts -t src/tests/types/testnet -n testnet src/tests/abis/testnet",
    "sync-from-sui": "tsx sync-from-sui.ts",
    "test": "tsx --test '**/*.test.ts'"
  },
  "types": "./dist/esm/index.d.ts",
  "dependencies": {
    "@iota/iota-sdk": "~1.14.0",
    "@typemove/move": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "prettier": "^3.8.3",
    "radash": "^12.1.1"
  }
}
