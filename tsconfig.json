{
  "compilerOptions": {
    "importHelpers": true,
    // TS 6 flipped `strict` to default-on. This project historically opted
    // into individual strict-family flags (strictNullChecks, noImplicitAny,
    // etc.) but never full strict, so pin it off to keep
    // strictPropertyInitialization / useUnknownInCatchVariables from breaking
    // the existing codebase.
    "strict": false,
    "declaration": true,
    "declarationMap": true,
    "alwaysStrict": true,
    "sourceMap": true,
    "target": "esnext",
    "lib": ["ESNext"],
    "types": ["node"],
    "esModuleInterop": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "isolatedModules": true,
    "strictNullChecks": true,
    "stripInternal": true,
    "noFallthroughCasesInSwitch": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  }
}
